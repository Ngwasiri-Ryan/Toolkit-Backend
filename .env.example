# Application Settings
PROJECT_NAME="ToolKit API"
VERSION="0.1.0"
API_V1_STR="/api/v1"

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Database Settings
DATABASE_URL="sqlite:///./toolkit.db"

# Authentication Settings
SUPABASE_JWT_SECRET="your_supabase_jwt_secret"

# Redis & Celery Settings
REDIS_URL="redis://localhost:6379/0"

# Storage Settings (AWS S3)
STORAGE_BUCKET="toolkit-uploads"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
S3_ENDPOINT_URL="your_s3_endpoint"

# Billing & Stripe Integration
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
PRO_PRICE_ID="your_pro_plan_price_id"

# Quota & Throttling Limits
FREE_DAILY_CONVERSION_LIMIT=5
MAX_FILE_SIZE_MB=50

# Transactional Email Notification
RESEND_API_KEY="your_resend_api_key"
RESEND_FROM_EMAIL="noreply@toolkit.dev"
